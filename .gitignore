# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map

# PWA
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
.env*.local

# Claude Code: 共有する設定 (settings.json / hooks / launch.json) は追跡し、
# ローカル成果物 (worktrees / 個人設定) は無視する
.claude/*
!.claude/settings.json
!.claude/launch.json
!.claude/hooks/
!.claude/hooks/**
.claude/settings.local.json

# Stitch生成物・デザイン比較画像(ローカル参照用)
.stitch/generated/
.stitch/refine/
